<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mixer Mode"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/text_primary" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/mixerModeSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:id="@+id/mixerStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:text="Mix two tracks with independent controls." />

        <TextView
            android:id="@+id/mixerSecondTrackText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:text="Second track: Not selected" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="12dp"
            android:background="@color/divider" />

        <Button
            android:id="@+id/mixerSelectSecondButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Select Second Audio" />

        <Button
            android:id="@+id/mixerBalanceButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:text="Adjust Volume Balance" />

        <Button
            android:id="@+id/mixerSyncButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:text="Sync Track Positions" />

        <Button
            android:id="@+id/mixerToggleIndividualSpeedButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:text="Enable Individual Speeds" />

        <LinearLayout
            android:id="@+id/mixerIndividualSpeedRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/mixerPrimarySpeedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Primary Speed" />

            <Button
                android:id="@+id/mixerSecondarySpeedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Secondary Speed" />
        </LinearLayout>

        <Button
            android:id="@+id/mixerClearSecondButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:text="Clear Second Audio" />

        <Button
            android:id="@+id/mixerSavedButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:text="Saved Mixer" />

    </LinearLayout>
</ScrollView>
