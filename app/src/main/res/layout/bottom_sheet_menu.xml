<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="16dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_icon_container" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Options"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:paddingHorizontal="20dp"
        android:paddingBottom="16dp" />

    <!-- Icon Grid: Row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:gravity="center">

        <!-- Sort -->
        <LinearLayout
            android:id="@+id/menu_sort_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_menu_grid_item"
            android:padding="14dp"
            android:layout_margin="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_sort"
                app:tint="@color/accent_primary"
                android:contentDescription="Sort" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sort"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- Timer -->
        <LinearLayout
            android:id="@+id/menu_timer_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_menu_grid_item"
            android:padding="14dp"
            android:layout_margin="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/menu_timer_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_bedtime"
                app:tint="@color/accent_primary"
                android:contentDescription="Sleep Timer" />
            <TextView
                android:id="@+id/menu_timer_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Timer"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- A-B Repeat -->
        <LinearLayout
            android:id="@+id/menu_ab_repeat_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_menu_grid_item"
            android:padding="14dp"
            android:layout_margin="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_ab_repeat"
                app:tint="@color/accent_primary"
                android:contentDescription="A-B Repeat" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A-B Loop"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- Playback Mode -->
        <LinearLayout
            android:id="@+id/menu_playback_mode_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_menu_grid_item"
            android:padding="14dp"
            android:layout_margin="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/menu_mode_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_repeat"
                app:tint="@color/accent_primary"
                android:contentDescription="Playback Mode" />
            <TextView
                android:id="@+id/menu_mode_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mode"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Spacer -->
    <View android:layout_width="match_parent" android:layout_height="4dp" />

    <!-- Icon Grid: Row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:gravity="center">

        <!-- Speed -->
        <LinearLayout
            android:id="@+id/menu_speed_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_menu_grid_item"
            android:padding="14dp"
            android:layout_margin="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_speed"
                app:tint="@color/accent_primary"
                android:contentDescription="Speed" />
            <TextView
                android:id="@+id/menu_speed_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Speed 1.0x"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- Equalizer -->
        <LinearLayout
            android:id="@+id/menu_equalizer_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_menu_grid_item"
            android:padding="14dp"
            android:layout_margin="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_tune"
                app:tint="@color/accent_primary"
                android:contentDescription="Equalizer" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Equalizer"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- Settings -->
        <LinearLayout
            android:id="@+id/menu_settings_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_menu_grid_item"
            android:padding="14dp"
            android:layout_margin="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                app:tint="@color/accent_primary"
                android:contentDescription="Settings" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- Refresh -->
        <LinearLayout
            android:id="@+id/menu_refresh_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_menu_grid_item"
            android:padding="14dp"
            android:layout_margin="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_refresh"
                app:tint="@color/accent_primary"
                android:contentDescription="Refresh" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Refresh"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Add to playlist (visible when song is playing) -->
    <LinearLayout
        android:id="@+id/menu_add_to_playlist_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_queue_music"
            app:tint="@color/text_secondary"
            android:contentDescription="Add to playlist" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Current Song to Playlist"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="12dp" />
    </LinearLayout>

</LinearLayout>
