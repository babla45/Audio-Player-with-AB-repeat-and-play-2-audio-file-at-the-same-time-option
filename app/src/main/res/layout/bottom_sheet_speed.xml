<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="24dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_icon_container" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="16dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_speed"
            app:tint="@color/accent_primary"
            android:contentDescription="Speed" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Playback Speed"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp" />

        <TextView
            android:id="@+id/speed_current_value"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:background="@drawable/gradient_accent"
            android:text="1.0x"
            android:textSize="13sp"
            android:textColor="@color/text_on_accent" />
    </LinearLayout>

    <!-- Speed Slider -->
    <SeekBar
        android:id="@+id/speed_seekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:min="1"
        android:max="16"
        android:progress="4"
        android:progressTint="@color/accent_primary"
        android:thumbTint="@color/accent_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0.25x"
            android:textSize="11sp"
            android:textColor="@color/text_tertiary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4.0x"
            android:textSize="11sp"
            android:textColor="@color/text_tertiary" />
    </LinearLayout>

    <!-- Quick preset chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/speed_chip_050"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.5x"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/speed_chip_075"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.75x"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/speed_chip_100"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.0x"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/speed_chip_125"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.25x"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/speed_chip_150"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.5x"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/speed_chip_200"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.0x"
                android:layout_marginEnd="8dp" />
        </LinearLayout>
    </HorizontalScrollView>
</LinearLayout>
