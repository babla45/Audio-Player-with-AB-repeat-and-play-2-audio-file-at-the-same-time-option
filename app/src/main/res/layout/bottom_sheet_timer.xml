<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="24dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_icon_container" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="16dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_bedtime"
            app:tint="@color/accent_primary"
            android:contentDescription="Timer" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sleep Timer"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- Quick presets -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/timer_chip_15"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15 min"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/timer_chip_30"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30 min"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/timer_chip_45"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="45 min"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/timer_chip_60"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="60 min"
                android:layout_marginEnd="8dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Custom input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Custom:"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/timer_custom_input"
            android:layout_width="80dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_icon_container"
            android:gravity="center"
            android:hint="min"
            android:textColorHint="@color/text_tertiary"
            android:textColor="@color/text_primary"
            android:inputType="numberDecimal"
            android:maxLength="5"
            android:padding="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="minutes"
            android:textColor="@color/text_tertiary"
            android:textSize="13sp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Timer action -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="When timer ends:"
        android:textColor="@color/text_secondary"
        android:textStyle="bold"
        android:textSize="14sp"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="4dp" />

    <RadioGroup
        android:id="@+id/timer_action_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp">

        <RadioButton
            android:id="@+id/timer_action_pause"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Pause playback"
            android:textColor="@color/text_primary"
            android:buttonTint="@color/accent_primary"
            android:checked="true" />

        <RadioButton
            android:id="@+id/timer_action_close"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Close app"
            android:textColor="@color/text_primary"
            android:buttonTint="@color/accent_primary" />
    </RadioGroup>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/timer_cancel_btn"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel Timer"
            android:textColor="@color/text_tertiary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/timer_set_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set Timer"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</LinearLayout>
