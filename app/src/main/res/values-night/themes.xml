<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark theme inherits from base (which is already dark) -->
    <style name="Base.Theme.Aud_player" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/text_on_accent</item>
        <item name="colorPrimaryContainer">@color/surface_700</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>

        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorOnSecondary">@color/text_on_accent</item>

        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface_800</item>
        <item name="colorSurfaceVariant">@color/surface_700</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/bottom_nav_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>

        <item name="colorControlHighlight">@color/ripple_light</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.App.BottomSheetDialog</item>
    </style>
</resources>